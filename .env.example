# Supabase (client-safe — use the anon/public key only)
# Copy this file to .env.local and fill in values from:
# https://supabase.com/dashboard/project/_/settings/api

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase Edge Function secrets (set in Supabase Dashboard → Edge Functions → Secrets)
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=Ticxnova <notifications@yourdomain.com>
